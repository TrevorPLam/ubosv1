# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================

# Frontend application port (required)
PORT=3000

# Frontend base path for routing (required)
BASE_PATH=/

# API server base URL for frontend (required)
VITE_API_BASE_URL=http://localhost:3001

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection string (required)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ubos

# =============================================================================
# LOGGING & OBSERVABILITY
# =============================================================================

# Log level: error, warn, info, debug (default: info)
LOG_LEVEL=info

# Node environment: development, production, test (default: development)
NODE_ENV=development

# =============================================================================
# OBSERVABILITY & MONITORING
# =============================================================================

# Sentry DSN for error tracking and performance monitoring (optional)
# Get this from your Sentry project settings
SENTRY_DSN=https://your-dsn-here@sentry.io/project-id

# Grafana Cloud API key for OpenTelemetry data export (optional)
# Used for sending traces, logs, and metrics to Grafana Cloud
GRAFANA_CLOUD_API_KEY=your-grafana-cloud-api-key-here

# OpenTelemetry endpoint for trace data (optional)
# Default: http://localhost:4317 (for local collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Frontend Sentry DSN (optional)
# Get this from your Sentry project settings
VITE_SENTRY_DSN=https://your-frontend-dsn-here@sentry.io/project-id

# =============================================================================
# AUTHENTICATION (Clerk)
# =============================================================================

# Clerk publishable key for frontend (required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# Clerk secret key for backend (required)
CLERK_SECRET_KEY=sk_test_your-secret-key-here

# =============================================================================
# AI MODEL PROVIDERS
# =============================================================================

# OpenAI API key for GPT models (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API key for Claude models (required for AI features)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# =============================================================================
# FILE STORAGE (S3-compatible)
# =============================================================================

# S3 access key for file storage
S3_ACCESS_KEY=your-s3-access-key-here

# S3 secret key for file storage
S3_SECRET_KEY=your-s3-secret-key-here

# S3 bucket name
S3_BUCKET=ubos-storage

# S3 endpoint URL (for non-AWS S3 providers)
S3_ENDPOINT=https://s3.amazonaws.com

# =============================================================================
# CACHE & QUEUES (Redis)
# =============================================================================

# Redis connection URL for caching and job queues
REDIS_URL=redis://localhost:6379

# =============================================================================
# COMMUNICATION SERVICES
# =============================================================================

# SendGrid API key for email sending
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Twilio account SID for SMS
TWILIO_ACCOUNT_SID=ACyour-twilio-account-sid-here

# Twilio auth token for SMS
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here

# =============================================================================
# PAYMENT PROCESSING (Stripe)
# =============================================================================

# Stripe secret key for payments
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key-here

# Stripe webhook secret for payment events
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
